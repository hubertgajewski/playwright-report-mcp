{
  "name": "playwright-report-mcp",
  "version": "3.2.2",
  "mcpName": "io.github.hubertgajewski/playwright-report-mcp",
  "description": "MCP server for running Playwright tests and reading structured results — designed for AI agents doing test failure analysis",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./dist/index.js": "./dist/index.js"
  },
  "bin": "./dist/index.js",
  "files": [
    "dist/**"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "playwright",
    "mcp",
    "model-context-protocol",
    "testing",
    "test-results",
    "ai",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hubertgajewski/playwright-report-mcp.git"
  },
  "homepage": "https://github.com/hubertgajewski/playwright-report-mcp#readme",
  "bugs": {
    "url": "https://github.com/hubertgajewski/playwright-report-mcp/issues"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "chmod-bin": "node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "build": "npm run clean && tsc && npm run chmod-bin",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "npm ci --prefix test/fixtures/pw-project && vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\" --ignore-path .gitignore"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26",
    "@vitest/coverage-v8": "^4.1.4",
    "prettier": "^3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
