{
  "name": "playwright-report-mcp",
  "version": "1.0.4",
  "mcpName": "io.github.hubertgajewski/playwright-report-mcp",
  "description": "MCP server for running Playwright tests and reading structured results — designed for AI agents doing test failure analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "files": [
    "dist/index.js"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "playwright",
    "mcp",
    "model-context-protocol",
    "testing",
    "test-results",
    "ai",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hubertgajewski/playwright-report-mcp.git"
  },
  "homepage": "https://github.com/hubertgajewski/playwright-report-mcp#readme",
  "bugs": {
    "url": "https://github.com/hubertgajewski/playwright-report-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "npm ci --prefix test/fixtures/pw-project && vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
